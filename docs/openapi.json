  "info": {
    "title": "Music Invest API",
    "description": "The API for music investment and crowdfunding platform",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com",
            "description": "User email address"
          },
          "password": {
            "type": "string",
            "example": "password123",
            "description": "User password",
            "minLength": 6
          },
          "role": {
            "type": "string",
            "example": "INVESTOR",
            "enum": [
              "USER",
              "ARTIST",
              "ADMIN"
            ],
            "description": "User role. Defaults to INVESTOR."
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com",
            "description": "User email address"
          },
          "password": {
            "type": "string",
            "example": "password123",
            "description": "User password",
            "minLength": 6
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "CreateProjectDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "My Awesome Album",
            "description": "The title of the project"
          },
          "description": {
            "type": "string",
            "example": "This album will blow your mind",
            "description": "Detailed project description"
          },
          "fundingGoal": {
            "type": "number",
            "example": 10000,
            "description": "Funding goal in USD"
          },
          "revenueSharePercent": {
            "type": "number",
            "example": 50,
            "description": "Percentage of revenue to share with investors",
            "minimum": 1,
            "maximum": 100
          },
          "durationMonths": {
            "type": "number",
            "example": 12,
            "description": "Duration of the project in months",
            "minimum": 1
          }
        },
        "required": [
          "title",
          "description",
          "fundingGoal",
          "revenueSharePercent",
          "durationMonths"
        ]
      },
      "CreateInvestmentDto": {
        "type": "object",
        "properties": {
          "projectId": {
            "type": "string",
            "example": "uuid-project-id",
            "description": "The ID of the project to invest in"
          },
          "amount": {
            "type": "number",
            "example": 100,
            "description": "Investment amount in USD",
            "minimum": 1
          }
        },
        "required": [
          "projectId",
          "amount"
        ]
      },
      "CreateRevenueReportDto": {
        "type": "object",
        "properties": {
          "projectId": {
            "type": "string",
            "example": "uuid-project-id",
            "description": "The related project ID"
          },
          "amount": {
            "type": "number",
            "example": 5000,
            "description": "Revenue amount generated in the period"
          },
          "periodStart": {
            "type": "string",
            "example": "2023-01-01T00:00:00Z",
            "description": "Period start date"
          },
          "periodEnd": {
            "type": "string",
            "example": "2023-01-31T23:59:59Z",
            "description": "Period end date"
          }
        },
        "required": [
          "projectId",
          "amount",
          "periodStart",
          "periodEnd"
        ]
      },
      "CreateAlbumDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "Title of the album",
            "example": "Nevermind"
          },
          "releaseDate": {
            "type": "string",
            "description": "Release date of the album (ISO 8601)",
            "example": "2025-06-01"
          }
        },
        "required": [
          "title"
        ]
      },
      "CreateTrackDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "Title of the track",
            "example": "Smells Like Teen Spirit"
          },
          "albumId": {
            "type": "string",
            "description": "Album ID representing the relation to the album",
            "example": "uuid-string"
          }
        },
        "required": [
          "title",
          "albumId"
        ]
      }
    }
  }
}